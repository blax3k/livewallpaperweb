{
  "name": "livewallpaper-backend",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "db:migrate": "tsx src/db/migrate.ts up",
    "db:migrate:down": "tsx src/db/migrate.ts down",
    "db:migrate:fake": "tsx src/db/migrate.ts up --fake",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@livewallpaper/types": "*",
    "@fastify/cors": "^10.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.3.2",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/pg": "^8.11.13",
    "tsx": "^4.19.4",
    "typescript": "^5.3.3"
  }
}
