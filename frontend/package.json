{
  "name": "livewallpaper-frontend",
  "version": "1.0.0",
  "scripts": {
    "build": "tsc --noEmit && npm run build:client",
    "build:client": "node scripts/build-client.mjs",
    "dev": "node scripts/build-client.mjs --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "clean": "rm -rf public/bundle.js public/bundle.css"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@testing-library/dom": "^9.3.4",
    "@types/jest": "^29.5.8",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.0",
    "esbuild-sass-plugin": "^3.7.0",
    "jest": "^29.7.0",
    "jest-canvas-mock": "^2.5.0",
    "jest-environment-jsdom": "^29.7.0",
    "sass": "^1.99.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@livewallpaper/types": "*",
    "pixi.js": "^8.18.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5"
  }
}
